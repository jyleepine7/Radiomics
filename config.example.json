{
  "manifest_path": "data/manifest.example.csv",
  "output_dir": "artifacts",
  "checkpoint_filename": "resnet18_backbone.pt",
  "preprocessing": {
    "target_depth": 64,
    "target_height": 96,
    "target_width": 96,
    "hu_min": -1000,
    "hu_max": 400,
    "bbox_margin": 8,
    "target_spacing_z": 2.5,
    "target_spacing_y": 1.0,
    "target_spacing_x": 1.0
  },
  "training": {
    "batch_size": 1,
    "epochs": 5,
    "learning_rate": 0.0001,
    "weight_decay": 0.00001,
    "validation_fraction": 0.2,
    "random_seed": 42,
    "num_workers": 0,
    "early_stopping_patience": 3
  },
  "model": {
    "backbone_name": "resnet18",
    "in_channels": 1,
    "embedding_pool": "avg",
    "conv1_t_size": 7,
    "conv1_t_stride": 1,
    "no_max_pool": false,
    "shortcut_type": "A",
    "widen_factor": 1.0,
    "bias_downsample": true,
    "weights_path": null
  },
  "features": {
    "batch_size": 1,
    "output_filename": "deep_features.csv"
  },
  "tabular": {
    "xlsx_path": "data/Radiomics_Clinical.xlsx",
    "prepared_output_filename": "prepared_dataset.csv",
    "evaluation_output_filename": "endpoint_metrics.json",
    "predictions_output_filename": "endpoint_predictions.csv",
    "radiomics_aggregations": [
      "mean",
      "max"
    ],
    "endpoint_windows_months": [
      12,
      36
    ]
  }
}
